# Copy this file to .env and fill in the values.
# Never commit .env to git.

# LLM API — Infineon internal endpoint
OPENAI_API_KEY=<api-token-from-permanent_token.py>
OPENAI_API_BASE=https://gpt4ifx.icp.infineon.com
LLM_MODEL=gpt-5.2

# MCP server (local)
MCP_SERVER_URL=http://localhost:8080/mcp

# Corporate CA bundle for internal TLS endpoints
SSL_CA_BUNDLE=ca-bundle.crt

# Set to false to skip SSL verification (useful for local/internal endpoints)
VERIFY_SSL=false


